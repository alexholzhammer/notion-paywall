# ── Application ─────────────────────────────────────────────────────────────
# Public base URL of the site (no trailing slash)
BASE_URL=https://paywall.automatisierer.io

# Port the Node.js server listens on (3000 is the default)
PORT=3000

# Set to "production" in Docker; enables secure cookies and production logging
NODE_ENV=production

# ── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# and share the target page with it.
NOTION_API_KEY=your_notion_integration_token_here

# The ID of the parent Notion page whose child pages are sold.
# Each child page is served at /content/<child-page-id>.
# Share the parent page (and all its children) with your integration.
# Find the ID in the URL: https://www.notion.so/My-Page-Title-<PAGE_ID>
# Copy the 32-char hex ID (with or without dashes).
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# How many blocks to show in the free preview (default: 5)
PREVIEW_BLOCKS=5

# ── Stripe ───────────────────────────────────────────────────────────────────
# Stripe secret key (sk_live_... for production, sk_test_... for testing)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# A Stripe Price ID for your product (create in Stripe Dashboard → Products)
STRIPE_PRICE_ID=your_stripe_price_id_here

# Webhook signing secret — obtained from the Stripe Dashboard or CLI:
#   stripe listen --forward-to https://paywall.automatisierer.io/webhook
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here

# Price string shown on the landing page button (display only)
STRIPE_PRICE_DISPLAY=€9.99

# ── Content ──────────────────────────────────────────────────────────────────
# Product / page name shown in the hero (falls back to the Notion page title)
PRODUCT_NAME=The Ultimate Automation Guide

# How long (ms) to cache the full Notion content in memory (default: 5 min)
CONTENT_CACHE_TTL_MS=300000

# ── Database ─────────────────────────────────────────────────────────────────
# Absolute path to the SQLite file (the Docker volume is mounted at /app/data)
DB_PATH=/app/data/paywall.db
